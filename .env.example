# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fashion_trends
# For SQLite (local dev, no Postgres needed):
# DATABASE_URL=sqlite+aiosqlite:///./fashion_trends.db

# ── Redis (for Celery job queue) ───────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Keys ───────────────────────────────────────────────
# Tagwalk API (https://tagwalk.com/api)
TAGWALK_API_KEY=your_tagwalk_api_key_here

# Google Cloud Vision (for image tagging)
GOOGLE_VISION_API_KEY=your_google_vision_key_here

# Optional: OpenAI for trend summarization
OPENAI_API_KEY=your_openai_key_here

# ── App settings ──────────────────────────────────────────
APP_ENV=development        # development | production
SECRET_KEY=change-me-to-a-random-secret-string
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Trend scoring weights (must sum to 1.0) ───────────────
WEIGHT_RUNWAY=0.50
WEIGHT_SEARCH=0.30
WEIGHT_SOCIAL=0.20

# ── Season to index ───────────────────────────────────────
ACTIVE_SEASON=FW26
ACTIVE_CITIES=Paris,Milan,London,New_York
